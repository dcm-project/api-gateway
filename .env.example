# Optional: copy to .env and set for local overrides or non-default credentials.
# Used by compose.yaml. Defaults (admin / adminpass) are for local dev only.
# POSTGRES_USER=admin
# POSTGRES_PASSWORD=adminpass

# K8s container service provider (profile: k8s-container)
# K8S_CONTAINER_SP_NAME=k8s-container-provider

# --- Service image versions ---
# Pin specific versions instead of "latest". Valid values:
#   latest        - most recent main build (default)
#   v1.2.0        - release branch (from version branch)
#   sha-abc1234   - specific commit build
# PLACEMENT_MANAGER_VERSION=latest
# SERVICE_PROVIDER_MANAGER_VERSION=latest
# CATALOG_MANAGER_VERSION=latest
# POLICY_MANAGER_VERSION=latest
# KUBEVIRT_SERVICE_PROVIDER_VERSION=latest
# K8S_CONTAINER_SERVICE_PROVIDER_VERSION=latest